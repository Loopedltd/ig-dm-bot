// ---- COACH PROMPT GENERATOR (single route, no duplicates) ----
app.post("/coach/api/generate-prompt", requireCoach, async (req, res) => {
  try {
    const { instagram_handle } = req.body || {};
    const handleRaw = String(instagram_handle || "").trim();
    if (!handleRaw) return safeJson(res, 400, { error: "instagram_handle is required" });

    const handle = handleRaw.startsWith("@") ? handleRaw.slice(1) : handleRaw;
    if (!/^[a-zA-Z0-9._]{1,30}$/.test(handle)) {
      return safeJson(res, 400, { error: "invalid instagram handle format" });
    }

    const { data: cfg } = await supabase.from("client_configs").select("*").eq("client_id", req.coach.client_id).single();
    const base = cfg?.system_prompt || "";

    if (!openai) {
      const stub = [
        "You are the coach's Instagram DM assistant.",
        "Tone: friendly, confident, concise, UK vibe.",
        "Write 1–2 short sentences max and end with ONE clear question.",
        "Never mention AI.",
        "If asked about price: ask goal + current situation, say you'll confirm exact options.",
        `Coach context: Instagram handle is @${handle}. Mirror their style (short, punchy, motivating).`,
      ].join("\n");
      return safeJson(res, 200, { ok: true, system_prompt: stub, used_ai: false });
    }

    const messages = [
      {
        role: "system",
        content: [
          "You write system prompts for an Instagram DM assistant for a coach.",
          "Output ONLY the system prompt text. No quotes, no markdown.",
          "Make it practical and specific.",
        ].join("\n"),
      },
      {
        role: "user",
        content: [
          `Coach Instagram handle: @${handle}`,
          "",
          "Goal: Create a strong system prompt for the coach's DM assistant.",
          "Constraints:",
          "- Keep it short but clear (8–14 lines).",
          "- UK tone, confident, not cringe.",
          "- 1–2 sentences per reply, end with ONE question.",
          "- If asked about price: ask goal + current situation; don't invent prices.",
          "- If high intent: guide to booking link (but don't spam).",
          "",
          "If there is an existing prompt, improve it while keeping the intent:",
          base ? `EXISTING_PROMPT:\n${base}` : "EXISTING_PROMPT: (none)",
        ].join("\n"),
      },
    ];

    const resp = await openai.chat.completions.create({
      model: process.env.OPENAI_MODEL || "gpt-4o-mini",
      messages,
      temperature: 0.5,
      max_tokens: 350,
    });

    const text = resp?.choices?.[0]?.message?.content?.trim();
    if (!text) return safeJson(res, 500, { error: "failed to generate prompt" });

    return safeJson(res, 200, { ok: true, system_prompt: text, used_ai: true });
  } catch (e) {
    return safeJson(res, 500, { error: String(e?.message || e) });
  }
});

// ===========================
// COACH STATS API (your existing one stays as-is in your project)
// NOTE: You already fixed replyRate to be <=100%.
// If you want manual override count surfaced to UI later, you can add it here.
// ===========================

// Root test
app.get("/", (req, res) => res.send("IG DM Bot is running"));

// Meta webhook verify
app.get("/webhook", (req, res) => {
  const mode = req.query["hub.mode"];
  const token = req.query["hub.verify_token"];
  const challenge = req.query["hub.challenge"];

  if (mode === "subscribe" && token === VERIFY_TOKEN) {
    console.log("✅ Webhook verified by Meta");
    return res.status(200).send(challenge);
  }
  console.warn("❌ Webhook verification failed");
  return res.sendStatus(403);
});

// ===========================
// INSTAGRAM WEBHOOK (POST)
// ===========================
app.post("/webhook", async (req, res) => {
  try {
    const { messaging } = parseIgEvent(req.body);

    // Ignore non-message updates
    if (!messaging) return res.sendStatus(200);

    const senderId = messaging.sender?.id;
    const text = extractIgText(messaging);
    const isEcho = isIgEcho(messaging);

    // Nothing useful to do
    if (!senderId || !text) return res.sendStatus(200);

    // 1️⃣ Find or create lead (per senderId)
    let { data: lead, error: leadErr } = await supabase.from("leads").select("*").eq("ig_psid", senderId).single();

    // "PGRST116" is the "No rows found" code in PostgREST
    if (leadErr && leadErr.code !== "PGRST116") {
      console.error("Lead lookup error:", leadErr);
      return res.sendStatus(200);
    }

    if (!lead) {
      const { data: newLead, error: createErr } = await supabase
        .from("leads")
        .insert({
          ig_psid: senderId,
          stage: "new",
        })
        .select()
        .single();

      if (createErr) {
        console.error("Lead create error:", createErr);
        return res.sendStatus(200);
      }

      lead = newLead;
    }

    // 2️⃣ Store message
    // - Echo messages are "coach/manual outbound"
    // - Non-echo messages are inbound from user
    await supabase.from("messages").insert({
      lead_id: lead.id,
      direction: isEcho ? "out" : "in",
      text,
      created_at: new Date().toISOString(),
    });

    // If we don't know which client this lead belongs to, we can't reply safely anyway.
    if (!lead.client_id) {
      console.warn("⚠️ lead.client_id is missing; skipping reply for lead", lead.id);
      return res.sendStatus(200);
    }

    // 3️⃣ Load client config (needed for GLOBAL PAUSE + prompt)
    const { data: cfg, error: cfgErr } = await supabase
      .from("client_configs")
      .select("*")
      .eq("client_id", lead.client_id)
      .single();

    if (cfgErr) {
      console.error("Config lookup error:", cfgErr);
      return res.sendStatus(200);
    }

    // ✅ GLOBAL PAUSE: If coach has paused the bot completely, never reply to anyone.
    // Still log inbound messages (already done above).
    if (!isEcho && cfg?.bot_paused) {
      console.log("🛑 Bot globally paused for client", lead.client_id, "— skipping reply (lead", lead.id, ")");
      return res.sendStatus(200);
    }

    // 4️⃣ If coach replies manually (echo) => pause bot for THIS lead only
    // Also refresh manual_override_at on EVERY coach reply so the 24h timer is accurate.
    if (isEcho) {
      await setLeadManualOverride({
        leadId: lead.id,
        clientId: lead.client_id,
        enabled: true,
        reason: "Coach replied manually on Instagram",
        actor: "system",
      });

      console.log("🛑 Manual override enabled/refreshed (echo) for lead", lead.id);
      return res.sendStatus(200);
    }

    // 5️⃣ Manual override handling for inbound user messages
    if (lead.manual_override) {
      // ✅ Auto-resume after 24h of NO coach replies (echo)
      // We use manual_override_at as "last coach activity" timestamp (refreshed on each echo above).
      const H24 = 24 * 60 * 60 * 1000;
      const idleMs = msSince(lead.manual_override_at);

      if (idleMs > H24) {
        await setLeadManualOverride({
          leadId: lead.id,
          clientId: lead.client_id,
          enabled: false,
          reason: "Auto-resumed after 24h of no coach replies",
          actor: "system",
        });

        // reflect locally so this request continues
        lead.manual_override = false;
        console.log("✅ Auto-resumed bot after 24h idle for lead", lead.id);
      } else {
        console.log("🛑 Manual override ON — bot will not reply:", lead.id);
        return res.sendStatus(200);
      }
    }

    // 6️⃣ Generate AI reply
    const reply = await generateAiReply({
      cfg,
      lead,
      lastUserTextRaw: text,
      postCallMode: lead.call_completed,
      asksPrice: /price|cost|how much/i.test(text),
      highIntent: /ready|start|sign up|book/i.test(text),
      bookingUrl: cfg?.booking_url || null,
    });

    if (!reply) return res.sendStatus(200);

    // 7️⃣ Send reply via Meta
    // NOTE: Node 18+ has global fetch. If you're on older Node, you'll need to install/import node-fetch.
    await fetch(`https://graph.facebook.com/v19.0/me/messages?access_token=${process.env.PAGE_ACCESS_TOKEN}`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        recipient: { id: senderId },
        message: { text: reply },
      }),
    });

    // 8️⃣ Store outbound bot message
    await supabase.from("messages").insert({
      lead_id: lead.id,
      direction: "out",
      text: reply,
      created_at: new Date().toISOString(),
    });

    return res.sendStatus(200);
  } catch (err) {
    console.error("Webhook error:", err);
    return res.sendStatus(200);
  }
});

/**
 * ===========================
 * UI signals
 * ===========================
 * Per-lead:
 * - lead.manual_override === true  => “Bot paused – manual takeover”
 *
 * Global:
 * - cfg.bot_paused === true => “Bot paused – global manual mode”
 *
 * Coach UI can read:
 * - GET /coach/api/leads
 * - GET /coach/api/bot-paused
 * And write:
 * - POST /coach/api/leads/:leadId/manual-override
 * - POST /coach/api/bot-paused
 */

// ---- START SERVER ----
const PORT = process.env.PORT || 3000;
app.listen(PORT, () => console.log(`🚀 Server running on port ${PORT}`));
