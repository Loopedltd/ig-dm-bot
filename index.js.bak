    .eq("client_id", req.coach.client_id)
    .select()
    .single();

  if (error) return res.status(500).json(error);
  res.json({ ok: true, config: data });
});

// ---- COACH PROMPT GENERATOR (single route, no duplicates) ----
app.post("/coach/api/generate-prompt", requireCoach, async (req, res) => {
  try {
    const { instagram_handle } = req.body || {};
    const handleRaw = String(instagram_handle || "").trim();
    if (!handleRaw) return res.status(400).json({ error: "instagram_handle is required" });

    const handle = handleRaw.startsWith("@") ? handleRaw.slice(1) : handleRaw;
    if (!/^[a-zA-Z0-9._]{1,30}$/.test(handle)) {
      return res.status(400).json({ error: "invalid instagram handle format" });
    }

    const { data: cfg } = await supabase
      .from("client_configs")
      .select("*")
      .eq("client_id", req.coach.client_id)
      .single();

    const base = cfg?.system_prompt || "";

    if (!openai) {
      const stub = [
        "You are the coach's Instagram DM assistant.",
        "Tone: friendly, confident, concise, UK vibe.",
        "Write 1–2 short sentences max and end with ONE clear question.",
        "Never mention AI.",
        "If asked about price: ask goal + current situation, say you'll confirm exact options.",
        `Coach context: Instagram handle is @${handle}. Mirror their style (short, punchy, motivating).`,
      ].join("\n");
      return res.json({ ok: true, system_prompt: stub, used_ai: false });
    }

    const messages = [
      {
        role: "system",
        content: [
          "You write system prompts for an Instagram DM assistant for a coach.",
          "Output ONLY the system prompt text. No quotes, no markdown.",
          "Make it practical and specific.",
        ].join("\n"),
      },
      {
        role: "user",
        content: [
          `Coach Instagram handle: @${handle}`,
          "",
          "Goal: Create a strong system prompt for the coach's DM assistant.",
          "Constraints:",
          "- Keep it short but clear (8–14 lines).",
          "- UK tone, confident, not cringe.",
          "- 1–2 sentences per reply, end with ONE question.",
          "- If asked about price: ask goal + current situation; don't invent prices.",
          "- If high intent: guide to booking link (but don't spam).",
          "",
          "If there is an existing prompt, improve it while keeping the intent:",
          base ? `EXISTING_PROMPT:\n${base}` : "EXISTING_PROMPT: (none)",
        ].join("\n"),
      },
    ];

    const resp = await openai.chat.completions.create({
      model: process.env.OPENAI_MODEL || "gpt-4o-mini",
      messages,
      temperature: 0.5,
      max_tokens: 350,
    });

    const text = resp?.choices?.[0]?.message?.content?.trim();
    if (!text) return res.status(500).json({ error: "failed to generate prompt" });

    return res.json({ ok: true, system_prompt: text, used_ai: true });
  } catch (e) {
    return res.status(500).json({ error: String(e?.message || e) });
  }
});

// ===========================
// COACH STATS API (SAFE FOR YOUR CURRENT SCHEMA)
// ===========================
// This route is what your stats page is calling: /coach/api/stats
app.get("/coach/api/stats", requireCoach, async (req, res) => {
  try {
    const clientId = req.coach.client_id;

    // Pull leads: ONLY select columns that definitely exist (no booking_clicked_at)
    const { data: leads, error: leadsErr } = await supabase
      .from("leads")
      .select("id,created_at,client_id,booking_sent,call_completed,stage") // keep safe
      .eq("client_id", clientId);

    if (leadsErr) return res.status(500).json(leadsErr);

    const leadIds = (leads || []).map((l) => l.id).filter(Boolean);

    // Pull messages: select * so we never reference a missing column in SQL
    let messages = [];
    if (leadIds.length) {
      const { data: msgs, error: msgErr } = await supabase
        .from("messages")
        .select("*")
        .in("lead_id", leadIds);

      if (msgErr) return res.status(500).json(msgErr);
      messages = msgs || [];
    }

    // ---- Window helpers ----
    const withinMs = (date, ms) => Date.now() - new Date(date).getTime() <= ms;
    const H24 = 24 * 60 * 60 * 1000;
    const D7 = 7 * 24 * 60 * 60 * 1000;
    const D30 = 30 * 24 * 60 * 60 * 1000;

    // ---- Direction detection (because your messages table might not have `direction`) ----
    // We try common column names; if none exist, we safely return totals without inbound/outbound split.
    const sample = messages[0] || {};
    const has = (k) => Object.prototype.hasOwnProperty.call(sample, k);

    const directionMode = (() => {
      if (has("direction")) return "direction";           // 'in'/'out'
      if (has("is_from_user")) return "is_from_user";     // boolean
      if (has("from_me")) return "from_me";               // boolean (true=outbound)
      if (has("role")) return "role";                     // 'user'/'assistant'
      if (has("sender")) return "sender";                 // 'user'/'bot'
      return null;
    })();

    const isInbound = (m) => {
      if (!directionMode) return null;
      const v = m[directionMode];
      if (directionMode === "direction") {
        const s = String(v || "").toLowerCase();
        return s === "in" || s === "incoming" || s === "received";
      }
      if (directionMode === "is_from_user") return !!v;
      if (directionMode === "from_me") return !v;
      if (directionMode === "role") return String(v || "").toLowerCase() === "user";
      if (directionMode === "sender") return String(v || "").toLowerCase() === "user";
      return null;
    };

    const isOutbound = (m) => {
      if (!directionMode) return null;
      const v = m[directionMode];
      if (directionMode === "direction") {
        const s = String(v || "").toLowerCase();
        return s === "out" || s === "outgoing" || s === "sent";
      }
      if (directionMode === "is_from_user") return !v;
      if (directionMode === "from_me") return !!v;
      if (directionMode === "role") return String(v || "").toLowerCase() !== "user";
      if (directionMode === "sender") return String(v || "").toLowerCase() !== "user";
      return null;
    };

    const leadsH24 = (leads || []).filter((l) => withinMs(l.created_at, H24));
    const leadsD7 = (leads || []).filter((l) => withinMs(l.created_at, D7));
    const leadsD30 = (leads || []).filter((l) => withinMs(l.created_at, D30));

    const msgH24 = (messages || []).filter((m) => withinMs(m.created_at, H24));
    const msgD7 = (messages || []).filter((m) => withinMs(m.created_at, D7));
    const msgD30 = (messages || []).filter((m) => withinMs(m.created_at, D30));

    const countInbound = (arr) => {
      if (!directionMode) return 0;
      return arr.filter((m) => isInbound(m)).length;
    };
    const countOutbound = (arr) => {
      if (!directionMode) return 0;
      return arr.filter((m) => isOutbound(m)).length;
    };

    const conversationsAll = new Set((messages || []).map((m) => m.lead_id)).size;

    const inboundAll = countInbound(messages || []);
    const outboundAll = countOutbound(messages || []);

    // ✅ NEW: replyRate is now "conversation-based" and capped at 100%
    // "Of the conversations where the user messaged (inbound), what % did we reply to at least once?"
    let replyRate = 0;
    if (directionMode && (messages || []).length) {
      const perLead = new Map(); // lead_id -> { in: bool, out: bool }

      for (const m of messages || []) {
        const leadId = m.lead_id;
        if (!leadId) continue;

        if (!perLead.has(leadId)) perLead.set(leadId, { in: false, out: false });

        const entry = perLead.get(leadId);
        if (isInbound(m)) entry.in = true;
        if (isOutbound(m)) entry.out = true;
      }

      let inboundConvos = 0;
      let repliedConvos = 0;

      for (const v of perLead.values()) {
        if (v.in) {
          inboundConvos += 1;
          if (v.out) repliedConvos += 1;
        }
      }

      replyRate =
        inboundConvos === 0
          ? 0
          : Math.min(100, Math.round((repliedConvos / inboundConvos) * 100));
    }

    const packWindow = (ls, ms) => ({
      leads: ls.length,
      conversations: new Set(ms.map((m) => m.lead_id)).size,
      repliesSent: countOutbound(ms),
      inboundMsgs: countInbound(ms),
      outboundMsgs: countOutbound(ms),
    });

    // Booking clicks: since your leads table doesn't have booking_clicked_at,
    // we return 0 for now (you can wire this later when you track it)
    const bookingClicks = 0;

    return res.json({
      ok: true,
      clientId,
      windows: {
        h24: packWindow(leadsH24, msgH24),
        d7: packWindow(leadsD7, msgD7),
        d30: packWindow(leadsD30, msgD30),
      },
      totals: {
        leads: (leads || []).length,
        conversations: conversationsAll,
        repliesSent: outboundAll,
        inboundMsgs: inboundAll,
        outboundMsgs: outboundAll,
        replyRate,
        bookingClicks,
      },
      meta: {
        directionMode, // helps debugging
      },
    });
  } catch (e) {
    return res.status(500).json({ error: String(e?.message || e) });
  }
});

// ===========================
// EXISTING API (YOUR BOT)
// ===========================

// Root test
app.get("/", (req, res) => res.send("IG DM Bot is running"));

// Meta webhook verify
app.get("/webhook", (req, res) => {
  const mode = req.query["hub.mode"];
  const token = req.query["hub.verify_token"];
  const challenge = req.query["hub.challenge"];

  if (mode === "subscribe" && token === VERIFY_TOKEN) {
    console.log("✅ Webhook verified by Meta");
    return res.status(200).send(challenge);
  }
  console.warn("❌ Webhook verification failed");
  return res.sendStatus(403);
});

// ---- START SERVER ----
const PORT = process.env.PORT || 3000;
app.listen(PORT, () => console.log(`🚀 Server running on port ${PORT}`));
