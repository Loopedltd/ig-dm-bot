a<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Coach Dashboard</title>
    <style>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
        background: #0b0f18;
        color: #e6edf7;
      }
      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 18px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.03);
        position: sticky;
        top: 0;
      }
      .brand {
        font-weight: 800;
      }
      .btn {
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        color: #e6edf7;
        padding: 10px 12px;
        border-radius: 12px;
        cursor: pointer;
        font-weight: 700;
      }
      .btn.primary {
        background: #2d6bff;
        border: 0;
      }
      .wrap {
        max-width: 920px;
        margin: 0 auto;
        padding: 18px;
      }
      .card {
        margin-top: 16px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        padding: 16px;
      }
      h1 {
        margin: 6px 0 0;
        font-size: 22px;
      }
      .muted {
        color: #a9b7d0;
        font-size: 13px;
        margin-top: 6px;
      }
      label {
        display: block;
        margin-top: 14px;
        color: #a9b7d0;
        font-size: 13px;
      }
      input,
      textarea {
        width: 100%;
        margin-top: 6px;
        padding: 12px;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        background: rgba(0, 0, 0, 0.25);
        color: #e6edf7;
        outline: none;
        box-sizing: border-box;
      }
      textarea {
        min-height: 200px;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
      .row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
      }
      .actions {
        display: flex;
        gap: 10px;
        margin-top: 14px;
        justify-content: flex-end;
      }
      .err { color: #ff6b6b; margin-top: 10px; display:none; }
      .ok  { color: #0bffb0; margin-top: 10px; display:none; }
      @media (max-width: 720px) {
        .row { grid-template-columns: 1fr; }
      }
    </style>
  </head>

  <body>
    <div class="topbar">
      <div class="brand">Looped — Coach</div>
      <div style="display:flex; gap:10px;">
        <button class="btn" id="refreshBtn">Refresh</button>
        <button class="btn" id="logoutBtn">Logout</button>
      </div>
    </div>

    <div class="wrap">
      <h1 id="title">Coach Dashboard</h1>
      <div class="muted">Edit your bot settings below.</div>

      <div class="card">
        <div class="row">
          <div>
            <label>Booking URL</label>
            <input id="booking_url" placeholder="https://calendly.com/yourname/15min" />
          </div>
          <div>
            <label>Alt Booking URL (optional)</label>
            <input id="booking_url_alt" placeholder="https://…" />
          </div>
        </div>

        <label>Coach instructions (we’ll convert this into the final AI prompt)</label>
        <textarea id="system_prompt"></textarea>

        <div class="actions">
          <button class="btn primary" id="saveBtn">Save</button>
        </div>

        <div class="err" id="err"></div>
        <div class="ok" id="ok">Saved ✅</div>
      </div>
    </div>

    <script src="./coach.js"></script>
  </body>
</html>
