/* global window, document, fetch, localStorage */

const CoachLogin = {
  async init() {
    const f = document.getElementById("f");
    if (!f) return;

    const btn = document.getElementById("btn");
    const err = document.getElementById("err");
    const ok = document.getElementById("ok");

    f.addEventListener("submit", async (e) => {
      e.preventDefault();
      err.style.display = "none";
      ok.style.display = "none";
      btn.disabled = true;

      try {
        const email = document.getElementById("email").value.trim();
        const password = document.getElementById("password").value;

        const r = await fetch("/coach/api/login", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email, password }),
        });

        const j = await r.json().catch(() => ({}));
        if (!r.ok) throw new Error(j?.error || "Login failed");

        localStorage.setItem("coach_token", j.token);
        ok.textContent = "Logged in. Redirecting…";
        ok.style.display = "block";
        window.location.href = "/coach/dashboard.html";
      } catch (e2) {
        err.textContent = String(e2.message || e2);
        err.style.display = "block";
      } finally {
        btn.disabled = false;
      }
    });
  },
};

const CoachDashboard = {
  token: null,

  authHeaders() {
    return {
      "Content-Type": "application/json",
      Authorization: `Bearer ${this.token}`,
    };
  },

  show(id, msg) {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent = msg || "";
    el.style.display = msg ? "block" : "none";
  },

  requireTokenOrRedirect() {
    const token = localStorage.getItem("coach_token");
    if (!token) {
      window.location.href = "/coach/login.html";
      return false;
    }
    this.token = token;
    return true;
  },

  bindLogout() {
    const b = document.getElementById("logoutBtn");
    if (!b) return;
    b.addEventListener("click", () => {
      localStorage.removeItem("coach_token");
      window.location.href = "/coach/login.html";
    });
  },

  async init() {
    if (!this.requireTokenOrRedirect()) return;

    this.bindLogout();

    document.getElementById("refreshBtn")?.addEventListener("click", () => {
      this.loadAll();
    });

    document.getElementById("saveBtn")?.addEventListener("click", () => {
      this.save();
    });

    await this.loadAll();
  },

  async loadAll() {
    this.show("err", "");
    this.show("ok", "");

    try {
      const meR = await fetch("/coach/api/me", { headers: this.authHeaders() });
      const meJ = await meR.json().catch(() => ({}));
      if (!meR.ok) throw new Error(meJ?.error || "Failed to load profile");

      document.getElementById("title").textContent =
        `Coach Dashboard — ${meJ?.client?.name || "Your account"}`;

      const r = await fetch("/coach/api/config", { headers: this.authHeaders() });
      const j = await r.json().catch(() => ({}));
      if (!r.ok) throw new Error(j?.error || "Failed to load config");

      const cfg = j.config || {};
      document.getElementById("booking_url").value = cfg.booking_url || "";
      document.getElementById("booking_url_alt").value = cfg.booking_url_alt || "";
      document.getElementById("system_prompt").value = cfg.system_prompt || "";
    } catch (e) {
      this.show("err", String(e.message || e));
    }
  },

async save() {
  this.show("err", "");
  this.show("ok", "");

  try {
    const token = localStorage.getItem("coach_token"); // must match what login stored
    if (!token) throw new Error("Missing coach token. Please log in again.");

    const bookingUrl = document.getElementById("booking_url")?.value?.trim() || "";
    const bookingUrlAlt = document.getElementById("booking_url_alt")?.value?.trim() || "";
    const systemPrompt = document.getElementById("system_prompt")?.value?.trim() || "";

    const payload = {
      booking_url: bookingUrl ? bookingUrl : null,
      booking_url_alt: bookingUrlAlt ? bookingUrlAlt : null,
      system_prompt: systemPrompt,
    };

    const r = await fetch("/coach/api/config", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${token}`,
      },
      body: JSON.stringify(payload),
    });

    const j = await r.json().catch(() => ({}));

    if (!r.ok) {
      throw new Error(j?.error || j?.message || `Save failed (HTTP ${r.status})`);
    }

    this.show("ok", "Saved ✅");
    await this.loadAll();
  } catch (e) {
    this.show("err", String(e?.message || e));
  }
}
      const r = await fetch("/coach/api/config", {
        method: "POST",
        headers: this.authHeaders(),
        body: JSON.stringify(payload),
      });

      const j = await r.json().catch(() => ({}));
      if (!r.ok) throw new Error(j?.error || "Save failed");

      this.show("ok", "Saved ✅");
    } catch (e) {
      this.show("err", String(e.message || e));
    }
  },
};

window.CoachLogin = CoachLogin;
window.CoachDashboard = CoachDashboard;
